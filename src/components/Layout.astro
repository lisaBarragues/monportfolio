---
import Navbar from "./Navbar.astro";
const { title = "Portfolio", description = "" } = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
  </head>
  <body>
    <Navbar />
    <main class="container">
      <slot />
    </main>
  </body>
</html>

<style>
  body{margin:0;font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial;background:#0b0b0b;color:#fff}
  .container{max-width:1000px;margin:0 auto;padding:28px 18px}
</style>
