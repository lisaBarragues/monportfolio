---
import Navbar from "./Navbar.astro";
const { title = "Portfolio", description = "" } = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
  </head>
  <body>
    <Navbar />
    <main class="container">
      <slot />
    </main>
  </body>
</html>

<style>
:root {
  --bg: #F5F1E8;            /* beige clair */
  --surface: #FFFFFF;       /* cartes */
  --surface-2: #E8F0EA;     /* vert très léger */
  --border: rgba(60, 80, 60, 0.12);

  --accent: #E67E22;        /* orange */
  --accent-soft: #F2B880;   /* orange doux */
  --accent-2: #8FBFA3;      /* vert céladon */

  --text: #2F2A26;          /* texte principal */
  --muted: rgba(47, 42, 38, 0.6);

  --radius: 18px;
}

body {
  margin: 0;
  font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial;

  background:
    radial-gradient(600px 400px at 20% 10%, rgba(143,191,163,0.15), transparent 70%),
    radial-gradient(500px 300px at 80% 20%, rgba(230,126,34,0.10), transparent 70%),
    var(--bg);

  color: var(--text);
  line-height: 1.7;
  font-size: 16px;
}

.container {
  max-width: 1100px;
  margin: 0 auto;
  padding: 36px 24px 80px;
}

:global(.card) {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius);
  box-shadow: 0 6px 18px rgba(0,0,0,0.06);
}

:global(a) { 
  color: var(--accent); 
  text-decoration: none; 
}
:global(a:hover) { 
  color: var(--accent-2); 
}
:global(.muted) { color: var(--muted); }
</style>
