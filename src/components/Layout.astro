---
import Navbar from "./Navbar.astro";
const { title = "Portfolio", description = "" } = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
  </head>
  <body>
    <Navbar />
    <main class="container">
      <slot />
    </main>
  </body>
</html>

<style>
:root {
  --bg: #1C1A1E;
  --surface: #232027;
  --surface-2: #2B2730;
  --border: rgba(210, 185, 220, 0.12);
  --accent: #B06090;
  --accent-2: #D4A8C4;
  --text: #EDE8EC;
  --muted: rgba(237, 232, 236, 0.58);
  --radius: 18px;
}

body {
  margin: 0;
  font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial;
  background:
    radial-gradient(800px 500px at 15% 10%, rgba(176, 96, 144, 0.10), transparent 65%),
    radial-gradient(700px 400px at 80% 20%, rgba(212, 168, 196, 0.07), transparent 60%),
    var(--bg);
  color: var(--text);
  line-height: 1.7;
  font-size: 16px;
}

.container {
  max-width: 1100px;
  margin: 0 auto;
  padding: 36px 24px 80px;
}

:global(.card) {
  background: linear-gradient(160deg, rgba(255,255,255,.025), rgba(255,255,255,.008));
  border: 1px solid var(--border);
  border-radius: var(--radius);
}

:global(a) { color: var(--accent-2); text-decoration: none; }
:global(a:hover) { color: var(--text); }
:global(.muted) { color: var(--muted); }
</style>
