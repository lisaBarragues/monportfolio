---
const links = [
  { href: "/", label: "Accueil" },
  { href: "/realisations", label: "Réalisations" },
  { href: "/competences", label: "Compétences" },
  { href: "/contact", label: "Contact" },
];
---

<header class="wrap">
  <nav class="nav">
    <a class="brand" href="/">Portfolio Lisa Barragues</a>
    <div class="links">
      {links.map(l => <a href={l.href}>{l.label}</a>)}
    </div>
  </nav>
</header>

<style>
  .wrap{position:sticky;top:0;z-index:10;background:var(--card);border-bottom:1px solid var(--border)}
  .nav{max-width:1000px;margin:0 auto;display:flex;justify-content:space-between;align-items:center;padding:14px 18px;color:#fff}
  .brand{font-weight:700;text-decoration:none;color:inherit}
  .links{display:flex;gap:16px}
  .links a{opacity:.85;text-decoration:none;color:inherit}
  .links a:hover{ color: var(--accent-soft)}
</style>
