---
const links = [
  { href: "/", label: "Accueil" },
  {
    href: "/realisations", label: "Réalisations",
    dropdown: [
      { href: "/realisations/alternance", label: "Alternance Easybourse" },
      { href: "/realisations/myplatformer", label: "MyPlatformer" },
      { href: "/realisations/doodle-jump", label: "Doodle Jump" },
      { href: "/realisations/catan", label: "Catan" },
      { href: "/realisations/compostelle", label: "Compostelle" }
    ],
  },
  {
    href: "/competences", label: "Compétences",
    dropdown: [
      { href: "/competences/python", label: "Python" },
      { href: "/competences/java", label: "Java" },
      { href: "/competences/sql", label: "SQL" },
      { href: "/competences/git", label: "Git" },
      { href: "/competences/communication", label: "Communication" },
      { href: "/competences/esprit-equipe", label: "Esprit d'équipe" },
      { href: "/competences/autonomie", label: "Autonomie" },
      { href: "/competences/adaptabilite", label: "Adaptabilite" },
      { href: "/competences/rigueur", label: "Rigueur" },
      { href: "/competences/organisation", label: "Organisation" },
    ],
  },
  { href: "/contact", label: "Contact" },
];
---

<header class="wrap">
  <nav class="nav">
    <a class="brand" href="/">Portfolio Lisa Barragues</a>
    <div class="links">
      {links.map(l =>
        l.dropdown ? (
          <div class="dropdown">
            <a href={l.href} class="dropdown-toggle">{l.label} ▾</a>
            <ul class="dropdown-menu">
              {l.dropdown.map(item => (
                <li><a href={item.href}>{item.label}</a></li>
              ))}
            </ul>
          </div>
        ) : (
          <a href={l.href}>{l.label}</a>
        )
      )}
    </div>
  </nav>
</header>

<style>
  .wrap {
    position: sticky;
    top: 0;
    z-index: 10;
    background: #1c151c;
    border-bottom: 1px solid var(--border);
  }
  .nav {
    max-width: 1000px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 18px;
    color: #fff;
  }
  .brand {
    font-weight: 700;
    text-decoration: none;
    color: inherit;
  }
  .links {
    display: flex;
    gap: 16px;
    align-items: center;
  }
  .links > a {
    opacity: 0.85;
    text-decoration: none;
    color: inherit;
  }
  .links > a:hover {
    color: var(--accent-soft);
  }

  /* Dropdown */
  .dropdown {
    position: relative;
  }
  .dropdown-toggle {
    cursor: pointer;
    opacity: 0.85;
    font: inherit;
    color: inherit;
    user-select: none;
    text-decoration: none;
  }
  .dropdown-toggle:hover {
    color: var(--accent-soft);
  }
  .dropdown-menu {
    display: none;
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    background: #181218;
    border: 1px solid var(--border);
    border-radius: 8px;
    list-style: none;
    padding: 10px 0;
    margin: 0;
    min-width: 180px;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
  }
  .dropdown-menu li a {
    display: block;
    padding: 8px 16px;
    color: inherit;
    text-decoration: none;
    opacity: 0.85;
    white-space: nowrap;
  }
  .dropdown-menu li a:hover {
    color: var(--accent-soft);
    background: rgba(255, 255, 255, 0.05);
  }
  .dropdown:hover .dropdown-menu {
    display: block;
  }
</style>