---
const links = [
  { href: "/", label: "Accueil" },
  { href: "/realisations", label: "Réalisations" },
  { href: "/competences", label: "Compétences" },
  { href: "/a-propos", label: "À propos" },
  { href: "/contact", label: "Contact" },
];
---

<nav class="nav">
  <a class="logo" href="/">Portfolio</a>
  <div class="links">
    {links.map(l => (
      <a href={l.href}>{l.label}</a>
    ))}
  </div>
</nav>

<style>
  .nav{display:flex;justify-content:space-between;align-items:center;padding:16px 24px;position:sticky;top:0;background:#0b0b0b;color:#fff}
  .links{display:flex;gap:16px}
  a{color:inherit;text-decoration:none;opacity:.85}
  a:hover{opacity:1}
  .logo{font-weight:700}
</style>
