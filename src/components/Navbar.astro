---
const links = [
  { href: "/", label: "Accueil" },
  {
    href: "/realisations", label: "Réalisations",
    dropdown: [
      { href: "/realisations/alternance", label: "Automatisation" },
      { href: "/realisations/myplatformer", label: "MyPlatformer" },
      { href: "/realisations/doodle-jump", label: "Doodle Jump" },
      { href: "/realisations/catan", label: "Catan" },
      { href: "/realisations/compostelle", label: "Compostelle" }
    ],
  },
  {
    href: "/competences", label: "Compétences",
    dropdown: [
      { href: "/competences/python", label: "Python" },
      { href: "/competences/java", label: "Java" },
      { href: "/competences/sql", label: "SQL" },
      { href: "/competences/git", label: "Git" },
      { href: "/competences/communication", label: "Communication" },
      { href: "/competences/esprit-equipe", label: "Esprit d'équipe" },
      { href: "/competences/autonomie", label: "Autonomie" },
      { href: "/competences/adaptabilite", label: "Adaptabilité" },
      { href: "/competences/rigueur", label: "Rigueur" },
      { href: "/competences/organisation", label: "Organisation" },
    ],
  },
  { href: "/contact", label: "Contact" },
];
---

<header class="wrap">
  <nav class="nav">
    <a class="brand" href="/">Portfolio Lisa Barragues</a>
    <div class="links">
      {links.map(l =>
        l.dropdown ? (
          <div class="dropdown">
            <a href={l.href} class="dropdown-toggle">{l.label} ▾</a>
            <ul class="dropdown-menu">
              {l.dropdown.map(item => (
                <li><a href={item.href}>{item.label}</a></li>
              ))}
            </ul>
          </div>
        ) : (
          <a href={l.href}>{l.label}</a>
        )
      )}
    </div>
  </nav>
</header>

<style>
  .wrap {
    position: sticky;
    top: 0;
    z-index: 10;
    background: #ede4d2;
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
  }

  .nav {
    max-width: 1000px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 18px;
    color: var(--text);
  }

  .brand {
    font-weight: 700;
    text-decoration: none;
    color: var(--text);
  }

  .brand:hover {
    color: var(--accent);
  }

  .links {
    font-weight: 700;
    display: flex;
    gap: 16px;
    align-items: center;
  }

  .links > a {
    opacity: 0.85;
    text-decoration: none;
    color: var(--text);
    transition: .2s ease;
  }

  .links > a:hover {
    opacity: 1;
    color: var(--accent);
  }

  /* Dropdown */
  .dropdown {
    position: relative;
  }

  .dropdown-toggle {
    cursor: pointer;
    opacity: 0.85;
    font: inherit;
    color: var(--text);
    user-select: none;
    text-decoration: none;
    transition: .2s ease;
  }

  .dropdown-toggle:hover {
    opacity: 1;
    color: var(--accent);
  }

  .dropdown-menu {
    display: none;
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    list-style: none;
    padding: 8px;
    margin: 0;
    min-width: 180px;
    box-shadow: 0 10px 24px rgba(0, 0, 0, 0.08);
  }

  .dropdown-menu li a {
    display: block;
    padding: 9px 14px;
    color: var(--text);
    text-decoration: none;
    opacity: 0.85;
    white-space: nowrap;
    border-radius: 10px;
    transition: .2s ease;
  }

  .dropdown-menu li a:hover {
    opacity: 1;
    color: var(--accent);
    background: var(--surface-2);
  }

  .dropdown:hover .dropdown-menu {
    display: block;
  }
</style>