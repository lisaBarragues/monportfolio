---
import Layout from "../../components/Layout.astro";

export async function getStaticPaths() {

  const modules = import.meta.glob("../../content/competences/*.{md,mdx}");

  const paths = [];

  for (const path in modules) {
    const mod = await modules[path]();
    const slug = path.split("/").pop().replace(/\.(md|mdx)$/, "");

    paths.push({
      params: { slug },
      props: {
        frontmatter: mod.frontmatter,
        Content: mod.default
      }
    });
  }

  return paths;
}

const { frontmatter, Content } = Astro.props;
---

<Layout title={`${frontmatter.title} — Compétences`}>
  <a href="/competences" style="opacity:.8">← Retour</a>

  <h1>{frontmatter.title}</h1>

  <article class="prose">
    <Content />
  </article>

  <style>
    .prose{
      line-height: 1.6;
      opacity: .92;
      max-width: 75ch;
    }
    .prose :global(a){
      text-decoration: underline;
      text-underline-offset: 3px;
    }
    .prose :global(h2){ margin-top: 18px; }
    .prose :global(ul){ padding-left: 18px; }
  </style>
</Layout>