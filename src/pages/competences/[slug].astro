---
import Layout from "../../components/Layout.astro";
import competences from "../../content/competences.json";

export function getStaticPaths() {
  return competences.map(c => ({ params: { slug: c.slug }, props: { c } }));
}

const { c } = Astro.props;
---

<Layout title={`${c.titre} — Compétences`}>
  <a href="/competences" style="opacity:.8">← Retour</a>
  <h1>{c.titre}</h1>

  <p style="opacity:.85">
    Décris la compétence : définition + exemple concret + outils/technos si besoin.
  </p>

  <ul style="opacity:.85">
    <li>Exemple projet / situation</li>
    <li>Ce que tu as apporté</li>
    <li>Résultat</li>
  </ul>
</Layout>
