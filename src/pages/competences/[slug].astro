---
import Layout from "../../components/Layout.astro";

export async function getStaticPaths() {
  const modules = import.meta.glob("../../content/competences/*.{md,mdx}");

  const paths = [];
  for (const path in modules) {
    const mod = await modules[path]();
    const slug = path.split("/").pop().replace(/\.(md|mdx)$/, "");
    paths.push({
      params: { slug },
      props: {
        frontmatter: mod.frontmatter,
        Content: mod.default
      }
    });
  }
  return paths;
}

const { frontmatter, Content } = Astro.props;
---

<Layout title={`${frontmatter.title} — Compétences`}>
  <a href="/competences" class="back">← Retour</a>

  <section class="competence-layout">
    
    <div class="text">
      <h1>{frontmatter.title}</h1>

      <article class="prose">
        <Content />
      </article>
    </div>

    <div class="image-container">
      <img 
        src={`/images/competences/${frontmatter.image}`} 
        alt={frontmatter.title}
      />
    </div>

  </section>

  <style>
    .back{
      opacity:.7;
      text-decoration:none;
    }

    .competence-layout{
      display:grid;
      grid-template-columns: 1fr 220px;
      gap:50px;
      align-items:start;
      margin-top:20px;
    }

    .image-container{
      position:sticky;
      top:120px;
    }

    .image-container img{
      width:200px;
      height:200px;
      object-fit:contain;
      filter: drop-shadow(0 10px 25px rgba(0,0,0,.4));
    }

    h1{
      margin-bottom:18px;
      font-size:2rem;
      letter-spacing:.5px;
    }

    /* STYLE TEXTE PREMIUM */
    .prose{
      line-height:1.75;
      font-size:1rem;
      max-width:none;
      text-align: justify;
      color: var(--text);
    }

    .prose :global(p){
      margin-bottom:18px;
    }

    .prose :global(strong){
      font-weight:600;
      letter-spacing:.3px;
    }

    .prose :global(em){
      opacity:.9;
      font-style:italic;
    }

    .prose :global(ul){
      margin:18px 0;
      padding-left:20px;
    }

    .prose :global(li){
      margin-bottom:8px;
    }

    .prose :global(a){
      text-decoration:underline;
      text-underline-offset:4px;
      color: var(--accent-2);              /* couleur principale */
      border-bottom: 1px solid var(--accent-2);
      transition: .2s ease;
    }
    .prose :global(a:hover){
      color: var(--accent);
      border-bottom: 1px solid var(--accent);
    }

    /* responsive */
    @media (max-width: 900px){
      .competence-layout{
        grid-template-columns:1fr;
      }

      .image-container{
        order:-1;
        position:static;
        margin-bottom:20px;
        text-align:center;
      }
    }

  </style>

</Layout>