---
import Layout from "../../components/Layout.astro";

const modules = import.meta.glob("../../content/competences/*.{md,mdx}");
const entries = await Promise.all(
  Object.entries(modules).map(async ([path, loader]) => {
    const mod = await loader();
    const slug = path.split("/").pop().replace(/\.(md|mdx)$/, "");
    return { slug, frontmatter: mod.frontmatter };
  })
);

const humaines = entries
  .filter(e => e.frontmatter.type === "humaine")
  .sort((a,b) => (a.frontmatter.order ?? 999) - (b.frontmatter.order ?? 999));

const techniques = entries
  .filter(e => e.frontmatter.type === "technique")
  .sort((a,b) => (a.frontmatter.order ?? 999) - (b.frontmatter.order ?? 999));
---

<Layout title="Compétences — Portfolio">
  <h1>Compétences</h1>

  <h2 id="humaines">Humaines</h2>
  <div class="grid">
    {humaines.map(c => (
      <a class="card" href={`/competences/${c.slug}`}>{c.frontmatter.title}</a>
      <img class="card-image" src={`/images/competences/${c.frontmatter.image}`} alt={c.frontmatter.title}/>
    ))}
  </div>

  <h2 id="techniques" style="margin-top:22px">Techniques</h2>
  <div class="grid">
    {techniques.map(c => (
      <a class="card" href={`/competences/${c.slug}`}>{c.frontmatter.title}
      <img class="card-image" src={`/images/competences/${c.frontmatter.image}`} alt={c.frontmatter.title}/>
      </a>
    ))}
  </div>

  <style>
    .grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:12px;margin-top:10px}
    .card{padding:14px 16px;border-radius:16px;border:1px solid rgba(255,255,255,.10);text-decoration:none;color:inherit;opacity:.9}
    .card:hover{opacity:1;border-color:rgba(255,255,255,.22)}
    .card-image{width:100%;height:120px;object-fit:contain;}
  </style>
</Layout>