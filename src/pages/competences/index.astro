---
import Layout from "../../components/Layout.astro";

const modules = import.meta.glob("../../content/competences/*.{md,mdx}");
const entries = await Promise.all(
  Object.entries(modules).map(async ([path, loader]) => {
    const mod = await loader();
    const slug = path.split("/").pop().replace(/\.(md|mdx)$/, "");
    return { slug, frontmatter: mod.frontmatter };
  })
);

const humaines = entries
  .filter(e => e.frontmatter.type === "humaine")
  .sort((a,b) => (a.frontmatter.order ?? 999) - (b.frontmatter.order ?? 999));

const techniques = entries
  .filter(e => e.frontmatter.type === "technique")
  .sort((a,b) => (a.frontmatter.order ?? 999) - (b.frontmatter.order ?? 999));
---

<Layout title="Compétences — Portfolio">
  <h1>Compétences</h1>

  <h2 id="humaines">Humaines</h2>
  <div class="grid">
    {humaines.map(c => (
      <a class="card" href={`/competences/${c.slug}`}>
        <img class="card-image" src={`/images/competences/${c.frontmatter.image}`} alt={c.frontmatter.title}/>
        <span class="card-title">{c.frontmatter.title}</span>
      </a>
    ))}
  </div>
  <h2 id="techniques" style="margin-top:22px">Techniques</h2>
  <div class="grid">
    {techniques.map(c => (
      <a class="card" href={`/competences/${c.slug}`}>
        <img class="card-image" src={`/images/competences/${c.frontmatter.image}`} alt={c.frontmatter.title}/>
        <span class="card-title">{c.frontmatter.title}</span>
      </a>
    ))}
  </div>

  <style>
    .grid{
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
      gap:18px;
      margin-top:14px;
    }

    .card{
      display:flex;
      flex-direction:column;
      align-items:center;
      padding:20px 18px;
      border-radius:18px;
      border:1px solid rgba(255,255,255,.10);
      text-align:center;
      text-decoration:none;
      color:inherit;
      gap:18px;                /* espace image / texte */
      transition:.2s ease;
    }

    .card:hover{
      transform:translateY(-4px);
      border-color:rgba(255,255,255,.28);
    }

    .card-image{
      width:100%;
      height:130px;
      object-fit:contain;
    }

    .card-title{
      font-weight:700;         /* plus épais */
      font-size:1.05rem;
      letter-spacing:.3px;
    }
  </style>
</Layout>