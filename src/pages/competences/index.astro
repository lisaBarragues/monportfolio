---
import Layout from "../../components/Layout.astro";
import competences from "../../content/competences.json";

const humaines = competences
  .filter(e => e.type === "humaine");
  // .sort((a,b) => (a.order ?? 999) - (b.order ?? 999));

const techniques = competences
  .filter(e => e.type === "technique");
  // .sort((a,b) => (a.frontmatter.order ?? 999) - (b.frontmatter.order ?? 999));
---

<Layout title="Compétences — Portfolio">
  <h1>Compétences</h1>

  <p>Voici un aperçu de mes compétences, classées en deux catégories : techniques et humaines. Les graphiques ci-dessous illustrent mon niveau dans chacune d'elles.</p>
  <div class="graph">
    <img src="/images/competences/graph_techniques.png" alt=graphTech/>
    <img src="/images/competences/graph_humaines.png" alt=graphHum/>
  </div>  

  <h2 id="techniques" style="margin-top:35px">Techniques</h2>
  <div class="grid">
    {techniques.map(c => (
      <a class="card" href={`/competences/${c.slug}`}>
        <img class="card-image" src={`/images/competences/${c.image}`} alt={c.titre}/>
        <span class="card-title">{c.titre}</span>
      </a>
    ))}
  </div>

  <h2 id="humaines" style="margin-top:35px">Humaines</h2>
  <div class="grid">
    {humaines.map(c => (
      <a class="card" href={`/competences/${c.slug}`}>
        <img class="card-image" src={`/images/competences/${c.image}`} alt={c.titre}/>
        <span class="card-title">{c.titre}</span>
      </a>
    ))}
  </div>

  <style>
    .graph {
      align-items:center;
      display:inline flow-root;
      flex-direction:row;
      border: 2px solid rgba(165, 18, 18, 0.1);
      border-radius: 18px;
      background:var(--surface);
    }

    .grid{
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
      gap:18px;
      margin-top:14px;
    }

    .card{
      display:flex;
      flex-direction:column;
      align-items:center;
      padding:20px 18px;
      border-radius:18px;
      border:1px solid rgba(255,255,255,.10);
      text-align:center;
      text-decoration:none;
      color:inherit;
      gap:18px;                /* espace image / texte */
      transition:.2s ease;
    }

    .card:hover{
      transform:translateY(-4px);
      border-color:rgba(255,255,255,.28);
    }

    .card-image{
      width:140%;
      height:160px;
      object-fit:contain;
    }

    .card-title{
      font-weight:700;         /* plus épais */
      font-size:1.05rem;
      letter-spacing:.3px;
    }
  </style>
</Layout>