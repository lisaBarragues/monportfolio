---
import Layout from "../components/Layout.astro";
---

<Layout title="Contact — Portfolio">
  <section class="contact-container">
    <h1>Me contacter</h1>
    <p class="subtitle">
      N’hésitez pas à me contacter pour échanger ou collaborer.
    </p>

    <div class="contact-card">

      <a href="mailto:lisabarragues@outlook.fr" class="contact-item">
        <div class="icon">✉</div>
        <div>
          <div class="label">Email</div>
          <div class="value">lisabarragues@outlook.fr</div>
        </div>
      </a>

      <a href="https://www.linkedin.com/in/lisa-barragues-3b2b17320/" target="_blank" class="contact-item">
        <div class="icon">in</div>
        <div>
          <div class="label">LinkedIn</div>
          <div class="value">Voir mon profil</div>
        </div>
      </a>

      <a href="https://github.com/lisaBarragues" target="_blank" class="contact-item">
        <div class="icon">GH</div>
        <div>
          <div class="label">GitHub</div>
          <div class="value">Voir mes projets</div>
        </div>
      </a>

    </div>
  </section>

<style>
  .contact-container{
    text-align:center;
    margin-top:20px;
  }

  h1{
    font-size:2rem;
    margin-bottom:10px;
    color: var(--text);
  }

  .subtitle{
    color: var(--muted);
    margin-bottom:40px;
  }

  .contact-card{
    max-width:600px;
    margin:0 auto;
    display:flex;
    flex-direction:column;
    gap:18px;
  }

  .contact-item{
    display:flex;
    align-items:center;
    gap:18px;
    padding:18px 22px;
    border-radius:18px;
    border:1px solid var(--border);
    text-decoration:none;
    color:var(--text);
    transition:.25s ease;
    background:var(--surface);
    box-shadow:0 6px 18px rgba(0,0,0,.06);
  }

  .contact-item:hover{
    transform:translateY(-4px);
    border-color:var(--accent-soft);
  }

  .icon{
    width:48px;
    height:48px;
    border-radius:14px;
    display:flex;
    align-items:center;
    justify-content:center;
    font-weight:700;
    font-size:1.1rem;
    color:#fff;
    background:var(--accent);
  }

  .label{
    font-size:.85rem;
    color:var(--muted);
  }

  .value{
    font-weight:600;
    letter-spacing:.3px;
    margin-top:3px;
    color:var(--text);
  }

  @media (max-width:600px){
    .contact-item{
      flex-direction:column;
      text-align:center;
    }
  }
</style>
</Layout>