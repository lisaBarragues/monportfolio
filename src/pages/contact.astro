---
import Layout from "../components/Layout.astro";
---

<Layout title="Contact — Portfolio">
  <section class="contact-container">
    <h1>Me contacter</h1>
    <p class="subtitle">
      N’hésitez pas à me contacter pour échanger ou collaborer.
    </p>

    <div class="contact-card">

      <a href="mailto:lisabarragues@outlook.fr" class="contact-item">
        <div class="icon">✉</div>
        <div>
          <div class="label">Email</div>
          <div class="value">lisabarragues@outlook.fr</div>
        </div>
      </a>

      <a href="https://www.linkedin.com/" target="_blank" class="contact-item">
        <div class="icon">in</div>
        <div>
          <div class="label">LinkedIn</div>
          <div class="value">Voir mon profil</div>
        </div>
      </a>

      <a href="https://github.com/" target="_blank" class="contact-item">
        <div class="icon">GH</div>
        <div>
          <div class="label">GitHub</div>
          <div class="value">Voir mes projets</div>
        </div>
      </a>

    </div>
  </section>

  <style>
    .contact-container{
      text-align:center;
      margin-top:20px;
    }

    h1{
      font-size:2rem;
      margin-bottom:10px;
    }

    .subtitle{
      opacity:.75;
      margin-bottom:40px;
    }

    .contact-card{
      max-width:600px;
      margin:0 auto;
      display:flex;
      flex-direction:column;
      gap:18px;
    }

    .contact-item{
      display:flex;
      align-items:center;
      gap:18px;
      padding:18px 22px;
      border-radius:18px;
      border:1px solid rgba(255,255,255,.12);
      text-decoration:none;
      color:inherit;
      transition:.25s ease;
      background:rgba(255,255,255,.03);
    }

    .contact-item:hover{
      transform:translateY(-4px);
      border-color:rgba(255,255,255,.25);
      background:rgba(255,255,255,.05);
    }

    .icon{
      width:48px;
      height:48px;
      border-radius:14px;
      display:flex;
      align-items:center;
      justify-content:center;
      font-weight:700;
      font-size:1.1rem;
      background:rgba(255,255,255,.08);
    }

    .label{
      font-size:.85rem;
      opacity:.65;
    }

    .value{
      font-weight:600;
      letter-spacing:.3px;
      margin-top:3px;
    }

    @media (max-width:600px){
      .contact-item{
        flex-direction:column;
        text-align:center;
      }
    }
  </style>
</Layout>