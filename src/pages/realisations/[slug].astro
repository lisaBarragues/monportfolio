---
import Layout from "../../components/Layout.astro";

export async function getStaticPaths() {
  const modules = import.meta.glob("../../content/realisations/*.{md,mdx}");

  const paths = [];
  for (const path in modules) {
    const mod = await modules[path]();
    const slug = path.split("/").pop().replace(/\.(md|mdx)$/, "");
    paths.push({
      params: { slug },
      props: {
        frontmatter: mod.frontmatter,
        Content: mod.default
      }
    });
  }
  return paths;
}

const { frontmatter, Content } = Astro.props;
---

<Layout title={`${frontmatter.title} — Réalisations`}>
  <a href="/realisations" class="back">← Retour</a>
  
  <section class="realisation-layout">

   <div class="text">
      <h1>{frontmatter.title}</h1>

      <article class="prose">
        <Content />
      </article>
    </div>

  </section>

<style>
  .back {
    opacity: .7;
    text-decoration: none;
  }

  .realisation-layout {
    margin: 25px;
    align-items: start;
    margin-top: 20px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 22px;
    padding: 18px;
  }

  h1 {
    margin: 25px;
    margin-bottom: 18px;
    font-size: 2rem;
    letter-spacing: .5px;
  }

  /* PROSE — aligné sur la présentation générale */
  .prose {
    opacity: .92;
    line-height: 1.55;
    font-size: 0.98rem;
    max-width: none;
    text-align: justify;
    margin: 20px;
  }

  .prose :global(p) {
    margin: 0 0 10px;
  }

  .prose :global(strong) {
    font-weight: 600;
    letter-spacing: .3px;
  }

  .prose :global(em) {
    opacity: .9;
    font-style: italic;
  }

  .prose :global(ul) {
    margin: 10px 0;
    padding-left: 18px;
  }

  .prose :global(li) {
    margin-bottom: 8px;
  }

  /* Liens — style présentation générale */
  .prose :global(a:link),
  .prose :global(a:visited) {
    text-decoration: none;
    font-weight: bold;
    color: var(--accent);
  }

  .prose :global(a:active) {
    text-decoration: none;
    font-weight: bold;
    background-color: var(--accent);
  }

  /* responsive */
  @media (max-width: 900px) {
    .competence-layout {
      grid-template-columns: 1fr;
    }

    .image-container {
      order: -1;
      position: static;
      margin-bottom: 20px;
      text-align: center;
    }
  }
</style>
   
</Layout>
