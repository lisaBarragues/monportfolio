---
import Layout from "../../components/Layout.astro";
import realisations from "../../content/realisations.json";
---

<Layout title="Réalisations — Portfolio">
  <h1>Réalisations</h1>
  <div class="grid">
    {realisations.map(r => (
      <a class="card" href={`/realisations/${r.slug}`}>
        <span class="card-title">{r.titre}</span>
        <span class="card-date">{r.annee}</span>
         <div class="image-container">
        <img 
          src={`/images/realisations/${r.image}`} 
          alt={r.titre}
        />
      </div>
        <div class="card-resume">{r.resume}</div>
      </a>
    ))}
  </div>

  <style>
.grid{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
  gap:18px;
}

.card{
  aspect-ratio:1 / 1;
  padding:16px;

  display:flex;
  flex-direction:column;
  align-items:center;
  text-align:center;
  gap:6px;

  border-radius:18px;
  border:1px solid var(--border);
  text-decoration:none;
  color:inherit;
  transition:.25s ease;
  overflow:hidden; /* évite que ça déborde visuellement */
}

.card:hover{
  transform:translateY(-4px);
  border-color:rgba(255,255,255,.25);
}

.card-title{
  font-weight:700;
  font-size:1.05rem;
  line-height:1.25;
}

.card-date{
  font-size:.8rem;
  opacity:.6;
  margin-bottom:2px;
}

.image-container{
  width:100%;
  height:130px;
  display:flex;
  justify-content:center;
  align-items:center;
  flex-shrink:0;
}

.image-container img{
  width:140px;
  height:140px;
  object-fit:contain;
  filter: drop-shadow(0 10px 25px rgba(0,0,0,.4));
}

.card-resume{
  font-size:.88rem;
  opacity:.85;
  line-height:1.4;

  display:-webkit-box;
  -webkit-line-clamp:4;      /* limite à 4 lignes */
  -webkit-box-orient:vertical;
  overflow:hidden;
}
  </style>
</Layout>
